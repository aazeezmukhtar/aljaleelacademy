<%- include('../partials/header') %>

    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h1>Nexus SIS</h1>
                <p>Enter your credentials to access the portal</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger" style="margin-bottom: 20px;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form action="/auth/login" method="POST" class="enroll-form">
                        <div class="form-group">
                            <label for="staff_id">Staff ID</label>
                            <div class="input-with-icon">
                                <i class="bi bi-person-badge"></i>
                                <input type="text" id="staff_id" name="staff_id" placeholder="e.g. admin" required
                                    autofocus class="form-control">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="password">Password</label>
                            <div class="input-with-icon">
                                <i class="bi bi-key-fill"></i>
                                <input type="password" id="password" name="password" placeholder="••••••••" required
                                    class="form-control">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block"
                            style="margin-top: 20px; width: 100%; height: 50px; font-size: 1.1rem;">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In to Portal
                        </button>
                    </form>

                    <div class="login-footer">
                        <p>&copy; 2026 Nexus SIS Core. Offline-First Desktop Edition.</p>
                    </div>
        </div>
    </div>

    <style>
        .login-page {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--school-primary), var(--school-secondary));
            padding: 20px;
        }

        .login-card {
            background: white;
            width: 100%;
            max-width: 450px;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
            animation: slideUp 0.6s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-logo {
            width: 80px;
            height: 80px;
            background: var(--school-primary);
            color: white;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 20px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .login-header h1 {
            font-size: 2rem;
            color: #1e293b;
            margin-bottom: 8px;
        }

        .login-header p {
            color: #64748b;
            font-size: 0.95rem;
        }

        .input-with-icon {
            position: relative;
        }

        .input-with-icon i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            transition: color 0.3s;
        }

        .input-with-icon .form-control {
            padding-left: 45px;
        }

        .input-with-icon .form-control:focus+i {
            color: var(--school-primary);
        }

        .login-footer {
            margin-top: 30px;
            text-align: center;
            color: #94a3b8;
            font-size: 0.85rem;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-danger {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fee2e2;
        }
    </style>

    <%- include('../partials/footer') %>