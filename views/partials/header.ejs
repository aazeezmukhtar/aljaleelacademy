<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/main.css?v=3.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --school-primary: #6366f1;
            --school-secondary: #a855f7;
        }
    </style>
</head>

<body>
    <%- include('notification_bar') %>

    <!-- Mobile Top Bar (visible < 992px) -->
    <div class="mobile-topbar" id="mobile-topbar">
        <span class="mobile-topbar-title"><%= title %></span>
        <div class="mobile-topbar-actions">
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="notification-bell-container" onclick="toggleNotificationDropdown(event)" style="position:relative;">
                <i class="bi bi-bell-fill" style="font-size:1.4rem; color: var(--text-secondary);"></i>
                <span class="notification-badge" id="topbar-notif-badge"></span>
                <div class="notification-dropdown">
                    <div class="notification-header">
                        <strong>Notifications</strong>
                    </div>
                    <div class="notification-list"></div>
                </div>
            </div>
            <% } %>
        </div>
    </div>