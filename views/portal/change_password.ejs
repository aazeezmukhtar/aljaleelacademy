<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background: #f8fafc; color: #1e293b; font-family: 'Inter', sans-serif; margin: 0; padding: 0; }
        .portal-nav { background: var(--school-primary, #6366f1); color: white; padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; }
        .portal-main { max-width: 600px; margin: 60px auto; padding: 0 20px; }
        .card { background: white; padding: 40px; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

<nav class="portal-nav">
    <div style="display: flex; align-items: center; gap: 15px;">
        <h2 style="margin: 0; font-family: 'Playfair Display', serif; font-size: 1.5rem;">Nexus Scholar Portal</h2>
    </div>
    <div style="font-weight: 500;">
        <a href="/portal" style="color: white; text-decoration: none; margin-right: 15px;">&larr; Back to Dashboard</a>
    </div>
</nav>

<main class="portal-main">
    <div class="card">
        <h2 style="margin-top: 0;">Change Password</h2>
        <p style="color: #64748b; margin-bottom: 30px;">For your security, please use a strong and unique password.</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger" style="margin-bottom: 20px;"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success" style="margin-bottom: 20px;"><%= success %></div>
        <% } %>

        <form action="/portal/change-password" method="POST">
            <div class="form-group" style="margin-bottom: 20px;">
                <label style="font-weight: 600;">Current Password</label>
                <input type="password" name="current_password" class="form-control" required style="padding: 12px;">
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="font-weight: 600;">New Password</label>
                <input type="password" name="new_password" class="form-control" required style="padding: 12px;" minlength="6">
            </div>

            <div class="form-group" style="margin-bottom: 30px;">
                <label style="font-weight: 600;">Confirm New Password</label>
                <input type="password" name="confirm_password" class="form-control" required style="padding: 12px;" minlength="6">
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px; font-weight: 600;">Update Password</button>
        </form>
    </div>
</main>

</body>
</html>
